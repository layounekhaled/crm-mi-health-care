generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Prospect {
  id            String   @id @default(cuid())
  nom           String
  specialite    String?
  wilaya        String?
  telephone     String?
  whatsapp      String?
  etablissement String?
  source        String?   @default("prospection")
  isClient      Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  interactions  Interaction[]
  opportunities Opportunity[]
  afterSales    AfterSale[]
  eventLinks    EventProspect[]
  tasks         Task[]
  documentSends DocumentSend[]
}

model Event {
  id        String   @id @default(cuid())
  nom       String
  ville     String?
  date      DateTime
  type      String    @default("congres")
  marques   String?
  equipe    String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  prospects EventProspect[]
  tasks     Task[]
}

model EventProspect {
  id         String   @id @default(cuid())
  eventId    String
  prospectId String
  createdAt  DateTime @default(now())

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([eventId, prospectId])
}

model Opportunity {
  id            String    @id @default(cuid())
  clientId      String?
  nomProjet     String
  statut        String    @default("Nouveau")
  montantEstime Float?
  commercialId  String?
  motifPerte    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client       Prospect?  @relation(fields: [clientId], references: [id])
  commercial   Employee?  @relation(fields: [commercialId], references: [id])
  operations   Operation[]
  tasks        Task[]
  interactions Interaction[]
  charges      Charge[]
}

model Operation {
  id            String   @id @default(cuid())
  opportunityId String
  produit       String
  marque        String
  responsableId String?
  prixEstime    Float?
  marge         Float?
  statut        String   @default("en_attente")
  datePrevue    DateTime?
  priorite      String   @default("moyenne")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  responsable Employee?  @relation(fields: [responsableId], references: [id])
  tasks       Task[]
}

model Task {
  id            String    @id @default(cuid())
  titre         String
  type          String    @default("commerciale")
  assigneAId    String?
  prospectId    String?
  opportunityId String?
  operationId   String?
  eventId       String?
  description   String?
  dateEcheance  DateTime?
  priorite      String    @default("moyenne")
  statut        String    @default("en_attente")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assigneA    Employee?    @relation(fields: [assigneAId], references: [id])
  prospect    Prospect?    @relation(fields: [prospectId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  operation   Operation?   @relation(fields: [operationId], references: [id])
  event       Event?       @relation(fields: [eventId], references: [id])
  interactions Interaction[]
}

model Interaction {
  id            String   @id @default(cuid())
  type          String   @default("appel")
  prospectId    String?
  opportunityId String?
  taskId        String?
  afterSaleId   String?
  notes         String?
  date          DateTime @default(now())
  employeId     String?
  createdAt     DateTime @default(now())

  prospect    Prospect?    @relation(fields: [prospectId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  task        Task?        @relation(fields: [taskId], references: [id])
  afterSale   AfterSale?   @relation(fields: [afterSaleId], references: [id])
  employe     Employee?    @relation(fields: [employeId], references: [id])

  @@index([taskId])
  @@index([afterSaleId])
}

model AfterSale {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("livraison")
  statut    String   @default("en_attente")
  notes     String?
  date      DateTime?
  employeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Prospect @relation(fields: [clientId], references: [id])
  employe Employee? @relation(fields: [employeId], references: [id])
  interactions Interaction[]
}

model Employee {
  id        String   @id @default(cuid())
  nom       String
  email     String?
  telephone String?
  role      String   @default("commercial")
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities  Opportunity[]
  operations     Operation[]
  tasksAssigned  Task[]
  interactions   Interaction[]
  afterSales     AfterSale[]
  objectives     Objective[]
  user           User?
  chatParticipants ChatParticipant[]
  sentMessages   ChatMessage[]
  emailConfig    EmailConfig?
  leaveRequests    LeaveRequest[]
  approvedRequests LeaveRequest[] @relation("ApprovedRequests")
  leaveMovements   LeaveMovement[]
  documents        Document[]
  documentSends    DocumentSend[]
  chargesAsEmployee  Charge[] @relation("EmployeeCharges")
  chargesAsCreator   Charge[] @relation("ChargeCreator")
}

model Objective {
  id              String   @id @default(cuid())
  employeId       String
  mois            String
  caObjectif      Float?   @default(0)
  nbVentesObjectif Int?    @default(0)
  tachesObjectif  Int?     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employe Employee @relation(fields: [employeId], references: [id], onDelete: Cascade)

  @@unique([employeId, mois])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  motDePasse   String
  employeId    String?  @unique
  role         String   @default("commercial")
  actif        Boolean  @default(true)
  derniereConnexion DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employe      Employee?  @relation(fields: [employeId], references: [id])
  notifications Notification[]
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("info")
  titre       String
  message     String
  lue         Boolean  @default(false)
  lien        String?
  referenceId String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lue])
}

model ChatConversation {
  id        String   @id @default(cuid())
  type      String   @default("direct")   // "direct" or "group"
  nom       String?                        // Group name (optional for direct)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([updatedAt])
}

model ChatParticipant {
  id             String   @id @default(cuid())
  conversationId String
  employeId      String
  lastReadAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  employe      Employee         @relation(fields: [employeId], references: [id], onDelete: Cascade)

  @@unique([conversationId, employeId])
  @@index([employeId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  expediteurId   String
  contenu        String
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  expediteur   Employee         @relation(fields: [expediteurId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([expediteurId])
}

model EmailConfig {
  id             String   @id @default(cuid())
  employeId      String   @unique
  email          String
  imapHost       String?
  imapPort       Int      @default(993)
  imapTls        Boolean  @default(true)
  smtpHost       String?
  smtpPort       Int      @default(587)
  smtpTls        Boolean  @default(true)
  emailPassword  String?
  signature      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employe Employee @relation(fields: [employeId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id            String   @id @default(cuid())
  employeeId    String
  type          String   // leave / absence / recovery_work
  startDate     DateTime
  endDate       DateTime
  daysCount     Int
  reason        String?
  attachmentUrl String?
  status        String   @default("pending") // pending / approved / rejected
  adminComment  String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver  Employee? @relation("ApprovedRequests", fields: [approvedBy], references: [id])
  movements LeaveMovement[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
}

model LeaveMovement {
  id         String   @id @default(cuid())
  employeeId String
  type       String   // leave / absence / recovery / annual_credit / adjustment
  value      Int      // +N or -N
  sourceId   String?  // reference to LeaveRequest id
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  source   LeaveRequest? @relation(fields: [sourceId], references: [id])

  @@index([employeeId])
  @@index([type])
  @@index([date])
}

model CalendarDay {
  id        String   @id @default(cuid())
  date      DateTime @unique
  type      String   // working_day / weekend / holiday
  label     String?  // e.g. "Jour de l'an", "Fête de l'indépendance"
  createdAt DateTime @default(now())

  @@index([date])
  @@index([type])
}

model Product {
  id             String   @id @default(cuid())
  nom            String
  marque         String   // MIR / BOS / Löwenstein / Yuwell / Gelenke / Autres
  categorie      String?  // monitorage / ventilation / chirurgie / imagerie / etc.
  reference      String?
  description    String?
  prixReference  Float?
  actif          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([marque])
  @@index([categorie])
  @@index([actif])
}

model Document {
  id            String   @id @default(cuid())
  title         String
  description   String?
  brand         String   // MIR / BOS / Löwenstein / Yuwell / Gelenke / Autres
  productName   String?
  documentType  String   // catalogue / prospectus / fiche_technique / formation / sav / autre
  fileUrl       String   // URL publique Supabase
  filePath      String   // chemin storage
  fileName      String
  fileSize      Int      // en octets
  uploadedBy    String?  // employeId
  status        String   @default("active") // active / archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uploader     Employee?     @relation(fields: [uploadedBy], references: [id])

  @@index([brand])
  @@index([documentType])
  @@index([status])
}

model DocumentSend {
  id            String   @id @default(cuid())
  documentIds   String   // JSON array of document IDs
  sentBy        String?  // employeId
  recipientType String   // prospect / client / manual
  recipientId   String?  // prospect/client ID
  recipientEmail String
  message       String?
  sentAt        DateTime @default(now())
  status        String   @default("sent") // sent / failed

  sender   Employee? @relation(fields: [sentBy], references: [id])
  prospect Prospect? @relation(fields: [recipientId], references: [id])

  @@index([sentBy])
  @@index([recipientId])
  @@index([sentAt])
}

model Charge {
  id            String    @id @default(cuid())
  type          String    // hotel / restaurant / transport / divers
  montant       Float     // amount in DZD
  description   String?
  date          DateTime  @default(now())
  employeId     String    // the employee who incurred the expense
  opportunityId String?   // optional: link to an opportunity
  createdBy     String?   // employeId of who recorded it
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employe     Employee     @relation("EmployeeCharges", fields: [employeId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  creator     Employee?    @relation("ChargeCreator", fields: [createdBy], references: [id])

  @@index([employeId])
  @@index([opportunityId])
  @@index([type])
  @@index([date])
}
